# Copy this file to .env and fill the values

# Backend 
DATABASE_URL=
STORAGE_DIR=./storage
BROWSER_USER_DATA_DIR=./.browser_profiles


# SerpAPI — used for Google AI Overview (no browser needed)
# Get a free key (250 searches/mo) at https://serpapi.com/manage-api-key
SERP_API_KEY=

# Run timing
PROVIDER_TIMEOUT_SECONDS=90
STREAM_SETTLE_SECONDS=4

# Set HEADLESS=false the first time so you can log in to ChatGPT/Gemini.
# After login cookies are persisted to BROWSER_USER_DATA_DIR you can flip to true.
HEADLESS=false

# Remote stealth browser (production / cloud). When set, browser providers
# connect to a managed service instead of launching a local Chrome — the service
# provides residential IPs + stealth + CAPTCHA solving to pass Cloudflare from a
# server. Leave both blank to launch Chrome locally (dev / single machine).
#
# Steel.dev — a session is created per capture; get a key at https://steel.dev
# (takes precedence over BROWSER_REMOTE_CDP_URL when both are set):
STEEL_API_KEY=
# Passing Cloudflare (ChatGPT/Google) needs a proxy + CAPTCHA solving. These two
# require a PAID Steel plan (the free/hobby plan rejects them) — leave false on free:
STEEL_USE_PROXY=false
STEEL_SOLVE_CAPTCHA=false
# BYOP: your own residential proxy — works on any plan (alternative to STEEL_USE_PROXY):
STEEL_PROXY_URL=
# Persist + reuse one Steel profile per provider (clears Cloudflare once, then
# reuses the clearance — the free-tier reliability lever). Works on any plan.
STEEL_PERSIST_PROFILE=true
# Brightdata / Browserless — a static wss CDP URL instead:
#   Brightdata: wss://brd-customer-<id>-zone-<zone>:<pass>@brd.superproxy.io:9222
#   Browserless: wss://chrome.browserless.io?token=<key>
BROWSER_REMOTE_CDP_URL=


# API
API_HOST=127.0.0.1
API_PORT=8000


# Frontend
VITE_API_URL=http://127.0.0.1:8000


# Gemini LLM
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Local sentiment runs on a public HuggingFace model — no token required.
# Set HF_TOKEN only to lift model-download rate limits (a read scope is enough).
HF_TOKEN=

# --- API key rotation (optional) ---
# Comma-separated lists; the app round-robins and advances on quota/rate-limit.
# If set, these take precedence over the single keys above.
SERP_API_KEYS=
GEMINI_API_KEYS=

# --- Celery / Redis (optional) ---
# When CELERY_BROKER_URL is set, captures + NLP run on worker processes
# (survive API restarts, never block API responses). Otherwise they run as
# in-process FastAPI background tasks. Start a worker with:
#   celery -A backend.tasks.celery_app worker --loglevel=info
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# --- Cloudflare R2 / S3 object storage (optional) ---
# When configured, raw JSON + screenshots + HTML stream to the bucket instead of
# local ./storage (makes the app stateless / multi-instance). Otherwise local disk.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT_URL=
R2_PUBLIC_BASE_URL=

# --- Supabase Storage (S3-compatible, optional) ---
# When configured, raw JSON + screenshots + HTML stream to a Supabase Storage
# bucket instead of local ./storage (stateless / multi-instance). Otherwise local.
# Generate S3 access keys in Supabase: Storage → Settings → S3 access keys.
SUPABASE_PROJECT_REF=
SUPABASE_S3_REGION=
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_BUCKET=
SUPABASE_S3_ENDPOINT=
SUPABASE_STORAGE_PUBLIC=false 

# Supabase project URL (required for JWT verification via JWKS)
# Example: https://your-project-ref.supabase.co
SUPABASE_URL=

# Legacy Supabase JWT secret.
# Only needed for older projects that still use HS256 tokens.
# Optional legacy JWT secret (not used for ES256/JWKS projects)
SUPABASE_JWT_SECRET=
