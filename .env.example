# Backend
DATABASE_URL=
STORAGE_DIR=./storage
BROWSER_USER_DATA_DIR=./.browser_profiles


# SerpAPI — used for Google AI Overview (no browser needed)
# Get a free key (250 searches/mo) at https://serpapi.com/manage-api-key
SERP_API_KEY=

# Run timing
PROVIDER_TIMEOUT_SECONDS=90
STREAM_SETTLE_SECONDS=4

# Set HEADLESS=false the first time so you can log in to ChatGPT/Gemini.
# After login cookies are persisted to BROWSER_USER_DATA_DIR you can flip to true.
HEADLESS=false


# API
API_HOST=127.0.0.1
API_PORT=8000


# Frontend
VITE_API_URL=http://127.0.0.1:8000


# Gemini LLM
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# --- API key rotation (optional) ---
# Comma-separated lists; the app round-robins and advances on quota/rate-limit.
# If set, these take precedence over the single keys above.
SERP_API_KEYS=
GEMINI_API_KEYS=

# --- Celery / Redis (optional) ---
# When CELERY_BROKER_URL is set, captures + NLP run on worker processes
# (survive API restarts, never block API responses). Otherwise they run as
# in-process FastAPI background tasks. Start a worker with:
#   celery -A backend.tasks.celery_app worker --loglevel=info
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# --- Supabase Storage (S3-compatible, optional) ---
# When configured, raw JSON + screenshots + HTML stream to a Supabase Storage
# bucket instead of local ./storage (stateless / multi-instance). Otherwise local.
# Generate S3 access keys in Supabase: Storage → Settings → S3 access keys.
SUPABASE_PROJECT_REF=
SUPABASE_S3_REGION=
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_BUCKET=
SUPABASE_S3_ENDPOINT=
SUPABASE_STORAGE_PUBLIC=false