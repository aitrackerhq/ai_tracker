# Backend
DATABASE_URL=sqlite:///./ai_tracker.db
STORAGE_DIR=./storage
BROWSER_USER_DATA_DIR=./.browser_profiles

# SerpAPI — used for Google AI Overview (no browser needed)
# Get a free key (250 searches/mo) at https://serpapi.com/manage-api-key
SERP_API_KEY=46ce244764bb9ec50e3f44367863918e7c19ffd4057a26808bce6d1cc1453664

# Run timing — ChatGPT streaming can take 60-90s; keep this at 180+
PROVIDER_TIMEOUT_SECONDS=180
STREAM_SETTLE_SECONDS=3

# Set HEADLESS=false the first time so you can log in to ChatGPT/Gemini.
# After login cookies are persisted to BROWSER_USER_DATA_DIR you can flip to true.
HEADLESS=false

# API
API_HOST=127.0.0.1
API_PORT=8000

# Frontend
VITE_API_URL=http://127.0.0.1:8000
